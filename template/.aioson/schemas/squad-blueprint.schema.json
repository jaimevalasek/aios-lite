{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiosforge.dev/schemas/squad-blueprint.schema.json",
  "title": "AIOSON Squad Blueprint",
  "description": "Schema para blueprints intermediários de design de squad",
  "type": "object",
  "required": ["id", "slug", "name", "problem", "goal", "mode"],
  "properties": {
    "id": { "type": "string", "description": "UUID do blueprint" },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 50
    },
    "name": { "type": "string", "maxLength": 100 },
    "problem": { "type": "string", "description": "Problema principal" },
    "goal": { "type": "string", "description": "Objetivo prático" },
    "scope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "O que está dentro do escopo"
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "O que está explicitamente fora"
    },
    "mode": {
      "type": "string",
      "enum": ["content", "software", "research", "mixed"]
    },
    "domain": { "type": "string" },
    "executors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "role"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "focus": { "type": "array", "items": { "type": "string" } },
          "skills": { "type": "array", "items": { "type": "string" } },
          "genomes": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["slug"],
                  "properties": {
                    "slug": { "type": "string" },
                    "type": { "type": "string" },
                    "mode": { "type": "string" },
                    "source": { "type": "string" },
                    "priority": { "type": "integer" },
                    "version": { "type": "string" },
                    "evidenceMode": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string", "enum": ["local", "inherited", "catalog"] }
        }
      }
    },
    "mcps": { "type": "array", "items": { "type": "object" } },
    "genomes": { "type": "array", "items": { "type": "object" } },
    "genomeBindings": {
      "type": "object",
      "properties": {
        "squad": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["slug"],
                "properties": {
                  "slug": { "type": "string" },
                  "type": { "type": "string" },
                  "mode": { "type": "string" },
                  "source": { "type": "string" },
                  "priority": { "type": "integer" },
                  "version": { "type": "string" },
                  "evidenceMode": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            ]
          }
        },
        "executors": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["slug"],
                  "properties": {
                    "slug": { "type": "string" },
                    "type": { "type": "string" },
                    "mode": { "type": "string" },
                    "source": { "type": "string" },
                    "priority": { "type": "integer" },
                    "version": { "type": "string" },
                    "evidenceMode": { "type": "string" },
                    "notes": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "contentBlueprints": { "type": "array", "items": { "type": "object" } },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suposições feitas durante o design"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "probability": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "readiness": {
      "type": "object",
      "description": "Estado de prontidão (detalhado na Fase 2)"
    },
    "sourceDocs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "investigation": {
      "type": "object",
      "description": "Referência à investigação de domínio do @orache",
      "properties": {
        "slug": { "type": "string" },
        "path": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensionsCovered": { "type": "integer", "minimum": 0, "maximum": 7 },
        "date": { "type": "string", "format": "date" }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Score de confiança geral"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "userAdjustments": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
