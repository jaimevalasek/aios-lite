      "file": "mcp-init.schema.json"
    },
    {
      "id": "package_test",
      "command": "aios-lite test:package --json",
      "file": "package-test.schema.json"
    },
    {
      "id": "workflow_plan",
      "command": "aios-lite workflow:plan --json",
